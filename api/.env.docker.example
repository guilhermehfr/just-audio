# MinIO / S3 Configuration
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=password123
MINIO_BUCKET=audio
MINIO_REGION=auto

# Server Configuration
NODE_ENV=development
PORT=3000

# Audio Processing
MAX_CONCURRENT_JOBS=3
AUDIO_TEMP_DIR=/tmp/audios
MAX_DURATION=14400
MAX_FILE_SIZE=500
AUDIO_TTL=86400

# CORS
CORS_ORIGIN=*
