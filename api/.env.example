# MinIO / S3 Configuration
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=audio
MINIO_REGION=auto

# Server Configuration
NODE_ENV=development
PORT=3001

# Audio Processing
MAX_CONCURRENT_JOBS=3  # Number of concurrent audio processing jobs
AUDIO_TEMP_DIR=/tmp/audios
MAX_DURATION=14400     # seconds (4h)
MAX_FILE_SIZE=500      # MB
AUDIO_TTL=86400        # seconds (24h)

# CORS
CORS_ORIGIN=*          # Use specific origin in production

# MinIO Configuration for Production
MINIO_ENDPOINT=s3.amazonaws.com
MINIO_ACCESS_KEY=<aws_access_key>
MINIO_SECRET_KEY=<aws_secret_key>
MINIO_BUCKET=just-audio-prod
MINIO_REGION=us-west-2
