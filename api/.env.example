# MinIO / S3 Configuration
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_REGION=

# Server Configuration
NODE_ENV=development
PORT=3000

# Logging
LOG_LEVEL=info

# Audio Processing
AUDIO_TEMP_DIR=/tmp/just-audio
AUDIO_QUALITY=0        # yt-dlp quality: 0 = best, 9 = worst
MAX_DURATION=3600      # seconds (1h)
MAX_FILE_SIZE=500      # MB

# CORS
CORS_ORIGIN=*          # Use specific origin in production
