# MinIO / S3 Configuration
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=audio
MINIO_REGION=auto

# Server Configuration
NODE_ENV=development
PORT=3000

# Audio Processing
MAX_CONCURRENT_JOBS=3  # Number of concurrent audio processing jobs
AUDIO_TEMP_DIR=/tmp/audios
MAX_DURATION=14400     # seconds (4h)
MAX_FILE_SIZE=500      # MB
AUDIO_TTL=86400        # seconds (24h)

# CORS
CORS_ORIGIN=*          # Use specific origin in production


