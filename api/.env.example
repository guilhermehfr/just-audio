# MinIO / S3 Configuration
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_REGION=auto

# Server Configuration
NODE_ENV=development
PORT=3000

# Audio Processing
AUDIO_TEMP_DIR=/tmp/audios
AUDIO_QUALITY=0        # yt-dlp quality: 0 = best, 9 = worst
MAX_DURATION=14400     # seconds (4h)
MAX_FILE_SIZE=500      # MB
AUDIO_TTL=86400        # seconds (24h)

# CORS
CORS_ORIGIN=*          # Use specific origin in production
